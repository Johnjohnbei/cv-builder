# Convex
VITE_CONVEX_URL=

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# OpenRouter — PRIMARY provider (OpenAI-compatible gateway to Claude, GPT, Gemini, Llama)
# Set in Convex env vars, NOT here:
#   npx convex env set OPENROUTER_API_KEY <your-key>
# Get a key at https://openrouter.ai/keys

# Gemini — FALLBACK provider (free-tier emergency path)
# Set in Convex env vars, NOT here:
#   npx convex env set GEMINI_API_KEY <your-key>
# Get a key at https://aistudio.google.com/apikey
