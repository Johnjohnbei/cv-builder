{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Données de base de l'utilisateur et son CV source.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "UID Firebase Auth" },
        "email": { "type": "string", "format": "email" },
        "full_name": { "type": "string" },
        "base_cv_json": { "type": "object", "description": "Données extraites du PDF LinkedIn" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "JobDescription": {
      "title": "JobDescription",
      "description": "Offre d'emploi ciblée par l'utilisateur.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "job_title": { "type": "string" },
        "company_name": { "type": "string" },
        "raw_text": { "type": "string" },
        "extracted_keywords": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "job_title", "raw_text"]
    },
    "GeneratedCV": {
      "title": "GeneratedCV",
      "description": "CV généré par l'IA pour une offre spécifique.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "job_id": { "type": "string" },
        "tailored_content": { "type": "object" },
        "design_template_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "job_id", "tailored_content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Profils utilisateurs"
    },
    "/users/{userId}/jobs/{jobId}": {
      "schema": "JobDescription",
      "description": "Offres d'emploi par utilisateur"
    },
    "/users/{userId}/cvs/{cvId}": {
      "schema": "GeneratedCV",
      "description": "CV générés par utilisateur"
    }
  }
}
